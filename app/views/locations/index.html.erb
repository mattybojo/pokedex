<table cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered datatable display">
  <thead class="sorting">
  <tr>
    <th>ID</th>
    <th>Name</th>
  </tr>
  </thead>
  <tbody>

  <% @locations.each do |location| %>
      <tr>
        <td><%= location.id %></td>
        <td><%= link_to location.name, location_path(location.slug) %></td>
      </tr>
  <% end %>
  </tbody>
  <tfoot>
  </tfoot>
</table>