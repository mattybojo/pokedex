<h1><%= @location.name %></h1>
<h3><%= @location.description %></h3>

<% if !@pokemon_location.nil? %>
    <table cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered datatable display">
      <thead class="sorting">
      <tr>
        <th>Pokemon</th>
        <th>Morning</th>
        <th>Afternoon</th>
        <th>Evening</th>
        <th>Notes</th>
      </tr>
      </thead>
      <tbody>
        <% @pokemon_location.each do |pl| %>
          <% p = Pokemon.find(pl.pokemon_id) %>
          <tr>
            <td><%= link_to p.name, pokemon_path(p.slug) %></td>
            <% if !pl.time_of_day.nil? %>
                <td><%= 'x' unless !pl.time_of_day.include? 'M' %></td>
                <td><%= 'x' unless !pl.time_of_day.include? 'A' %></td>
                <td><%= 'x' unless !pl.time_of_day.include? 'E' %></td>
            <% else %>
                <td></td>
                <td></td>
                <td></td>
            <% end %>
            <td><%= pl.notes %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
      </tfoot>
    </table>
<% end %>